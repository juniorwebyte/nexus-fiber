DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirecionar assets estßticos para a pasta public do backend
    RewriteRule ^backend/(css|js|img|icon\.png|manifest\.json|sw\.js)(/.*)?$ backend/public/$1$2 [L]
    
    # Redirecionar todas as outras requisiń§es para o Router do backend
    RewriteRule ^backend/(.*)$ backend/public/index.php [QSA,L]
</IfModule>
